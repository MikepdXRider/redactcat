DATABASE_URL=sqlite:///./redactcat.db
APP_ENV=development

# Required for auth — use a long random string in production
JWT_SECRET=changeme

# AWS credentials — required for Comprehend, Textract, and S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for ephemeral job file storage
S3_BUCKET=
