DATABASE_URL=sqlite:///./redactcat.db
APP_ENV=development

# Required for auth — use a long random string (32+ chars) in production
JWT_SECRET=changeme
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# AWS credentials — required for Comprehend, Textract, and S3
AWS_PROFILE=

# S3 bucket for ephemeral job file storage
S3_BUCKET=

